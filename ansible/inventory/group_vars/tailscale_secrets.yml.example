---
# Tailscale authentication key
# 
# Generate at: https://login.tailscale.com/admin/settings/keys
# 
# Recommended settings:
# - Reusable: Yes (for multiple hosts)
# - Ephemeral: No (unless testing)
# - Pre-authorized: Yes (auto-approve devices)
# - Tags: tag:prod, tag:infra (for ACL management)
#
# To create the encrypted version:
# 1. Copy this file: cp tailscale_secrets.yml.example tailscale_secrets.yml
# 2. Edit with SOPS: sops tailscale_secrets.yml
# 3. Add your actual auth key
#
# NEVER commit the unencrypted version!

tailscale_auth_key: "tskey-auth-REPLACE_WITH_YOUR_KEY"
