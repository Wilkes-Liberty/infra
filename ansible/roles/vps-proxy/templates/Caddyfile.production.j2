# =============================================
# WilkesLiberty Production Caddyfile
# Njalla VPS Reverse Proxy Configuration
# =============================================
# All services proxy to on-prem server via Tailscale
# SSL certificates automatically managed by Caddy
# =============================================

# Global options
{
    email {{ letsencrypt_email | default('admin@wilkesliberty.com') }}

    admin off

    servers {
        protocols h1 h2 h3
    }
}

# ── Shared security header snippets ──────────────────────────────────────────

# Applied to all HTML-serving public vhosts (www)
(public_headers_html) {
    header {
        Strict-Transport-Security "max-age=63072000; includeSubDomains; preload"
        X-Frame-Options            "SAMEORIGIN"
        X-Content-Type-Options     "nosniff"
        X-XSS-Protection           "1; mode=block"
        Referrer-Policy            "strict-origin-when-cross-origin"
        Permissions-Policy         "geolocation=(), microphone=(), camera=(), payment=(), usb=()"
        # CSP: tighten per-app once inline scripts are audited
        # 'unsafe-inline' retained for Next.js — remove once nonces are implemented
        Content-Security-Policy    "default-src 'self'; script-src 'self' 'unsafe-inline' 'unsafe-eval'; style-src 'self' 'unsafe-inline'; img-src 'self' data: https:; font-src 'self' data:; connect-src 'self' https://api.wilkesliberty.com; frame-ancestors 'self'; base-uri 'self'"
        -Server
        -X-Powered-By
    }
}

# Applied to API vhosts (api, auth) — no HTML frame/CSP restrictions
(public_headers_api) {
    header {
        Strict-Transport-Security "max-age=63072000; includeSubDomains; preload"
        X-Content-Type-Options    "nosniff"
        Referrer-Policy           "no-referrer"
        -Server
        -X-Powered-By
    }
}

# ================== PUBLIC SERVICES ==================

# Root domain redirect to www
wilkesliberty.com {
    redir https://www.wilkesliberty.com{uri} permanent
}

# Main website (Next.js frontend)
www.wilkesliberty.com {
    # Next.js — systemd service wl-ui listening on 127.0.0.1:3000
    # Managed by the wl-vps-ui Ansible role
    reverse_proxy 127.0.0.1:3000 {
        header_up Host {host}
        header_up X-Real-IP {remote_host}
        header_up X-Forwarded-Proto {scheme}
        fail_duration 10s
    }

    # Fall back to the static holding page if Next.js is down
    handle_errors {
        @down expression {http.error.status_code} in [502, 503, 504]
        handle @down {
            root * /var/www/holding
            file_server
        }
    }

    import public_headers_html

    log {
        output file /var/log/caddy/www.log
        format json
    }
}

# Drupal GraphQL API (headless CMS)
api.wilkesliberty.com {
    # Proxy to on-prem server Drupal via Tailscale
    reverse_proxy {{ onprem_tailscale_ip }}:8080 {
        header_up Host {host}
        header_up X-Real-IP {remote_host}
        header_up X-Forwarded-For {remote_host}
        header_up X-Forwarded-Proto {scheme}
        
    }
    
    import public_headers_api

    # CORS — only allow the www frontend to call the API
    header {
        Access-Control-Allow-Origin  "https://www.wilkesliberty.com"
        Access-Control-Allow-Methods "GET, POST, OPTIONS"
        Access-Control-Allow-Headers "Content-Type, Authorization"
        Access-Control-Max-Age       "86400"
    }
    
    # Handle preflight requests
    @options {
        method OPTIONS
    }
    respond @options 204
    
    # Rate limiting (optional)
    # rate_limit {
    #     zone api {
    #         key {remote_host}
    #         events 100
    #         window 1m
    #     }
    # }
    
    log {
        output file /var/log/caddy/api.log
        format json
    }
}

# Keycloak SSO/Auth
auth.wilkesliberty.com {
    # Proxy to on-prem server Keycloak via Tailscale
    reverse_proxy {{ onprem_tailscale_ip }}:8081 {
        header_up Host {host}
        header_up X-Real-IP {remote_host}
        header_up X-Forwarded-For {remote_host}
        header_up X-Forwarded-Proto {scheme}
        
        # Keycloak-specific headers
        header_up X-Forwarded-Host {host}
        header_up X-Forwarded-Port 443
        
    }
    
    import public_headers_api

    log {
        output file /var/log/caddy/auth.log
        format json
    }
}

# Tailscale admin console bookmark
# A/AAAA point here (not a CNAME) so Caddy holds the TLS cert before redirecting.
# A direct CNAME to login.tailscale.com causes ERR_SSL_PROTOCOL_ERROR (SNI mismatch).
network.wilkesliberty.com {
    redir https://login.tailscale.com{uri} permanent
}

