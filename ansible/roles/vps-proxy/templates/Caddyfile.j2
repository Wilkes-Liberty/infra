wilkesliberty.com {
    # Proxy API calls to the Mac Mini via Tailscale (inner mesh)
    reverse_proxy /api* http://100.82.73.91:8080 {
        header_up X-Forwarded-For {remote_host}
    }

    # Proxy Keycloak SSO
    reverse_proxy /auth* http://100.82.73.91:8081

    # Proxy Next.js UI (running on the VPS itself)
    reverse_proxy / http://127.0.0.1:3000 {
        header_up X-Forwarded-For {remote_host}
    }

    # Optional: Add SSL (Caddy handles Let's Encrypt automatically)
    tls {
        protocols tls1.2 tls1.3
    }
}