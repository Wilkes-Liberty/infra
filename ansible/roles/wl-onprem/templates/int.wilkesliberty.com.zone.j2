; Zone file for int.wilkesliberty.com
; Served by CoreDNS on the Tailscale IP ({{ coredns_listen_ip }}) — internal use only.
; Managed by Ansible (wl-onprem role). Do not edit manually.
;
; ALL entries resolve to the Tailscale IP ({{ coredns_listen_ip }}) where internal
; Caddy listens. Caddy handles TLS and proxies each hostname to the correct backend.
; Do NOT resolve directly to LAN IPs here — Caddy binds only on the Tailscale
; interface and will not receive requests sent to a LAN IP.
;
; Serial uses Unix epoch truncated to hours — auto-increments on each playbook run.

$ORIGIN int.wilkesliberty.com.
$TTL 300

@    IN SOA  ns1.int.wilkesliberty.com. admin.wilkesliberty.com. (
             {{ ansible_date_time.epoch | int // 3600 }} ; serial (epoch/hour)
             3600   ; refresh
             900    ; retry
             604800 ; expire
             300 )  ; minimum TTL

     IN NS   ns1.int.wilkesliberty.com.

; ── Nameserver ────────────────────────────────────────────────────────────────
ns1          IN A    {{ coredns_listen_ip }}

; ── Application services ──────────────────────────────────────────────────────
; Caddy (on Tailscale IP) reverse proxies these to localhost Docker ports
api          IN A    {{ coredns_listen_ip }}
sso          IN A    {{ coredns_listen_ip }}
db           IN A    {{ coredns_listen_ip }}
search       IN A    {{ coredns_listen_ip }}
cache        IN A    {{ coredns_listen_ip }}

; ── Monitoring ────────────────────────────────────────────────────────────────
monitor      IN A    {{ coredns_listen_ip }}
metrics      IN A    {{ coredns_listen_ip }}
alerts       IN A    {{ coredns_listen_ip }}
uptime       IN A    {{ coredns_listen_ip }}

; ── Admin devices ─────────────────────────────────────────────────────────────
; Caddy proxies these to their LAN IPs (nas_int_ip, router_int_ip, etc.)
; with tls_insecure_skip_verify since devices use self-signed certs internally
nas          IN A    {{ coredns_listen_ip }}
router       IN A    {{ coredns_listen_ip }}
switch       IN A    {{ coredns_listen_ip }}
print        IN A    {{ coredns_listen_ip }}

; ── Staging ───────────────────────────────────────────────────────────────
; Caddy proxies these to staging Docker ports (8090, 8091, 8993, 3010)
; Hyphenated names keep us within the *.int.wilkesliberty.com wildcard cert
stg          IN A    {{ coredns_listen_ip }}
api-stg      IN A    {{ coredns_listen_ip }}
sso-stg      IN A    {{ coredns_listen_ip }}
search-stg   IN A    {{ coredns_listen_ip }}

; ── Bookmarks / external redirects ───────────────────────────────────────────
; These resolve to Caddy (Tailscale IP) which performs an HTTPS redirect to the
; real external URL. SNI is correct because Caddy holds the wildcard cert.
network      IN A    {{ coredns_listen_ip }}
{% if coredns_listen_ipv6 | default('') %}

; ── IPv6 AAAA records — mirrors every A record above ─────────────────────────
; Enable by setting onprem_tailscale_ipv6 in network_secrets.yml:
;   sops ansible/inventory/group_vars/network_secrets.yml
;   onprem_tailscale_ipv6: "$(tailscale ip -6)"
ns1          IN AAAA {{ coredns_listen_ipv6 }}
api          IN AAAA {{ coredns_listen_ipv6 }}
sso          IN AAAA {{ coredns_listen_ipv6 }}
db           IN AAAA {{ coredns_listen_ipv6 }}
search       IN AAAA {{ coredns_listen_ipv6 }}
cache        IN AAAA {{ coredns_listen_ipv6 }}
monitor      IN AAAA {{ coredns_listen_ipv6 }}
metrics      IN AAAA {{ coredns_listen_ipv6 }}
alerts       IN AAAA {{ coredns_listen_ipv6 }}
uptime       IN AAAA {{ coredns_listen_ipv6 }}
nas          IN AAAA {{ coredns_listen_ipv6 }}
router       IN AAAA {{ coredns_listen_ipv6 }}
switch       IN AAAA {{ coredns_listen_ipv6 }}
print        IN AAAA {{ coredns_listen_ipv6 }}
stg          IN AAAA {{ coredns_listen_ipv6 }}
api-stg      IN AAAA {{ coredns_listen_ipv6 }}
sso-stg      IN AAAA {{ coredns_listen_ipv6 }}
search-stg   IN AAAA {{ coredns_listen_ipv6 }}
network      IN AAAA {{ coredns_listen_ipv6 }}
{% endif %}
