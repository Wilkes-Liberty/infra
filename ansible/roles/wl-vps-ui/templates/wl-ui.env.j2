NODE_ENV=production
PORT=3000
HOSTNAME=127.0.0.1
NEXT_PUBLIC_SITE_URL={{ ui_site_url | default('https://wilkesliberty.com') }}
NEXT_PUBLIC_DRUPAL_BASE_URL={{ ui_drupal_base_url | default('https://api.wilkesliberty.com') }}
DRUPAL_BASE_URL={{ ui_drupal_base_url | default('https://api.wilkesliberty.com') }}
NEXT_IMAGE_DOMAIN={{ ui_image_domain | default('api.wilkesliberty.com') }}
NEXT_PUBLIC_IDENTITY_URL={{ ui_identity_url | default('https://auth.wilkesliberty.com') }}

# Webhook secret for Drupal-triggered ISR revalidation.
# Must match next.next_site.wilkesliberty_ui revalidate_secret in Drupal config.
DRUPAL_REVALIDATE_SECRET={{ drupal_revalidate_secret | default('') }}
DRUPAL_PREVIEW_SECRET={{ drupal_preview_secret | default('') }}

# OAuth client (optional — only needed for fetching protected/draft content).
DRUPAL_CLIENT_ID={{ drupal_client_id | default('') }}
DRUPAL_CLIENT_SECRET={{ drupal_client_secret | default('') }}
