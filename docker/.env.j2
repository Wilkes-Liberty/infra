# AUTO-GENERATED by Ansible — do not edit by hand.
# Source: ansible/roles/wl-onprem/tasks/main.yml (template task)
# Secrets: ansible/inventory/group_vars/sso_secrets.yml  (SOPS-encrypted)
#          ansible/inventory/group_vars/app_secrets.yml  (SOPS-encrypted)
