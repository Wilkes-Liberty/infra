# ── PostgreSQL / Drupal ───────────────────────────────────────────────────────
DRUPAL_DB_PASSWORD={{ drupal_db_password }}

# ── PostgreSQL / Keycloak ─────────────────────────────────────────────────────
KEYCLOAK_DB_PASSWORD={{ keycloak_db_password }}

# ── Keycloak Admin ────────────────────────────────────────────────────────────
KEYCLOAK_ADMIN_PASSWORD={{ keycloak_admin_password }}

# ── Redis ─────────────────────────────────────────────────────────────────────
REDIS_PASSWORD={{ redis_password }}

# ── Drupal ────────────────────────────────────────────────────────────────────
DRUPAL_HASH_SALT={{ drupal_hash_salt }}

# OAuth2 consumer credentials — created in Drupal at /admin/config/services/consumer.
# Leave empty until Drupal is fully installed; re-run make onprem afterwards.
DRUPAL_CLIENT_ID={{ drupal_client_id | default('') }}
DRUPAL_CLIENT_SECRET={{ drupal_client_secret | default('') }}

# Secret for on-demand Next.js ISR revalidation.
# Set the same value in Drupal at /admin/config/services/next.
DRUPAL_REVALIDATE_SECRET={{ drupal_revalidate_secret | default('') }}

# Secret for draft/preview mode — must match the Drupal Next.js module config.
DRUPAL_PREVIEW_SECRET={{ drupal_preview_secret | default('') }}

# ── Next.js ───────────────────────────────────────────────────────────────────
# Domain used for Next.js image optimization proxy.
NEXT_IMAGE_DOMAIN=api.{{ domain }}

# ── Grafana ───────────────────────────────────────────────────────────────────
GRAFANA_ADMIN_PASSWORD={{ grafana_admin_password }}

# ── Backup ────────────────────────────────────────────────────────────────────
BACKUP_NOTIFICATION_EMAIL={{ alert_email_to }}
BACKUP_ENCRYPTION_KEY={{ backup_encryption_key }}

# ── Alertmanager SMTP ─────────────────────────────────────────────────────────
# Alertmanager config is rendered by Ansible from config.yml.j2 — not by Docker.
# SMTP credentials: ansible/inventory/group_vars/sso_secrets.yml (SOPS-encrypted)
# SMTP host/port/from/to: ansible/inventory/group_vars/all.yml
