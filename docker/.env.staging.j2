# ── PostgreSQL / Drupal (staging) ─────────────────────────────────────────────
STG_DRUPAL_DB_PASSWORD={{ stg_drupal_db_password }}

# ── PostgreSQL / Keycloak (staging) ───────────────────────────────────────────
STG_KEYCLOAK_DB_PASSWORD={{ stg_keycloak_db_password }}

# ── Keycloak Admin (staging) ──────────────────────────────────────────────────
STG_KEYCLOAK_ADMIN_PASSWORD={{ stg_keycloak_admin_password }}

# ── Redis (staging) ───────────────────────────────────────────────────────────
STG_REDIS_PASSWORD={{ stg_redis_password }}

# ── Drupal (staging) ──────────────────────────────────────────────────────────
STG_DRUPAL_HASH_SALT={{ stg_drupal_hash_salt }}

# OAuth2 consumer credentials — created in staging Drupal at /admin/config/services/consumer.
# Leave empty until staging Drupal is fully installed; re-run make onprem afterwards.
STG_DRUPAL_CLIENT_ID={{ stg_drupal_client_id | default('drupal-client') }}
STG_DRUPAL_CLIENT_SECRET={{ stg_drupal_client_secret | default('') }}

# Secret for on-demand Next.js ISR revalidation.
# Set the same value in staging Drupal at /admin/config/services/next.
STG_DRUPAL_REVALIDATE_SECRET={{ stg_drupal_revalidate_secret | default('') }}

# ── Next.js (staging) ─────────────────────────────────────────────────────────
# 'drupal' = use Docker service name for SSR requests (correct for staging)
NEXT_STG_IMAGE_DOMAIN=drupal
