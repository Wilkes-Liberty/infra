# =============================================
# WilkesLiberty Docker Compose Environment
# =============================================
# Copy this file to .env and fill in all values before deploying:
#   cp .env.example .env
#
# Generate secure values with:
#   openssl rand -base64 32    (for passwords and secrets)
#   openssl rand -base64 55    (for Drupal hash salt — needs to be longer)
#
# IMPORTANT: Never commit .env to version control.
#            It is already in .gitignore.
# =============================================

# ── PostgreSQL / Drupal ───────────────────────────────────────────────────────
# Primary database password — used by Drupal and postgres service
# Generate: openssl rand -base64 32
DRUPAL_DB_PASSWORD=

# ── PostgreSQL / Keycloak ─────────────────────────────────────────────────────
# Keycloak gets its own dedicated database — do NOT reuse DRUPAL_DB_PASSWORD
# Generate: openssl rand -base64 32
KEYCLOAK_DB_PASSWORD=

# ── Keycloak Admin ────────────────────────────────────────────────────────────
# Keycloak web admin console password (username is always 'admin')
# Generate: openssl rand -base64 32
KEYCLOAK_ADMIN_PASSWORD=

# ── Drupal ────────────────────────────────────────────────────────────────────
# Cryptographic hash salt — must be long, random, and consistent across deploys.
# Changing this invalidates all sessions and one-time links.
# Generate: openssl rand -base64 55
DRUPAL_HASH_SALT=

# OAuth2 consumer credentials — created in Drupal at /admin/config/services/consumer
DRUPAL_CLIENT_ID=
DRUPAL_CLIENT_SECRET=

# Secret for on-demand Next.js ISR revalidation
# Generate: openssl rand -base64 32
# Set the same value in Drupal at /admin/config/services/next
DRUPAL_REVALIDATE_SECRET=

# ── Next.js ───────────────────────────────────────────────────────────────────
# Domain used for Next.js image optimization proxy
# Dev (Dockerized): use 'drupal' (Docker service name)
# Prod (VPS):       use your Drupal public hostname e.g. 'api.wilkesliberty.com'
NEXT_IMAGE_DOMAIN=drupal

# ── Grafana ───────────────────────────────────────────────────────────────────
# Grafana admin password — no default, must be set explicitly
# Generate: openssl rand -base64 32
GRAFANA_ADMIN_PASSWORD=

# ── Backup ────────────────────────────────────────────────────────────────────
# Email address for backup status notifications (uses macOS mail command)
BACKUP_NOTIFICATION_EMAIL=3@wilkesliberty.com

# AES-256 encryption key for backup archives
# Generate: openssl rand -base64 32
# Leave empty to skip encryption (not recommended for production)
BACKUP_ENCRYPTION_KEY=

# ── Alertmanager SMTP ─────────────────────────────────────────────────────────
# Note: Alertmanager config is rendered by Ansible from config.yml.j2, not by Docker.
# SMTP credentials belong in ansible/inventory/group_vars/sso_secrets.yml (SOPS-encrypted).
# SMTP host/port/from/to are in ansible/inventory/group_vars/all.yml.
# These variables are listed here for reference only — they are NOT read by docker-compose.
#
# alert_smtp_user: <your-smtp-user>         # → sso_secrets.yml (encrypted)
# alert_smtp_password: <your-smtp-password> # → sso_secrets.yml (encrypted)
# alert_slack_webhook_url: <webhook-url>    # → sso_secrets.yml (encrypted, optional)
