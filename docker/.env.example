# =============================================
# WilkesLiberty Docker Compose Environment Variables
# =============================================
# Instructions:
#   1. Copy this file to .env in the same directory
#   2. Replace placeholder values with actual secrets
#   3. Never commit .env to version control
# =============================================

# ── Database Credentials ──
DRUPAL_DB_PASSWORD=ChangeThisToAStrongPassword2026!

# ── SSO/Auth Credentials ──
KEYCLOAK_ADMIN_PASSWORD=ChangeThisToAStrongPassword2026!

# ── Monitoring Credentials ──
GRAFANA_ADMIN_PASSWORD=admin

# ── Alerting Configuration (Optional) ──
# SMTP settings for email alerts
ALERT_EMAIL_FROM=alerts@wilkesliberty.com
ALERT_EMAIL_TO=admin@wilkesliberty.com
ALERT_SMTP_HOST=smtp.example.com
ALERT_SMTP_PORT=587
ALERT_SMTP_USER=alerts@wilkesliberty.com
ALERT_SMTP_PASSWORD=your_smtp_password

# Slack webhook for alerts (optional)
ALERT_SLACK_WEBHOOK_URL=https://hooks.slack.com/services/YOUR/WEBHOOK/URL

# ── Backup Configuration ──
# Cloud backup encryption key (generate with: openssl rand -base64 32)
BACKUP_ENCRYPTION_KEY=your_encryption_key_here

# Backup notification email
BACKUP_NOTIFICATION_EMAIL=admin@wilkesliberty.com

# ── Notes ──
# - Generate strong passwords with: openssl rand -base64 32
# - Keycloak admin interface: http://localhost:8081
# - Grafana dashboard: http://localhost:3001
# - Prometheus: http://localhost:9090
# - Alertmanager: http://localhost:9093
