# =============================================
# WilkesLiberty Docker Compose Environment
# =============================================
# Copy this file to .env and fill in ALL values before deploying:
#   cp .env.example .env && chmod 600 .env
#
# Generate secure values with:
#   openssl rand -base64 32    (passwords and secrets)
#   openssl rand -base64 55    (Drupal hash salt — must be longer)
#
# IMPORTANT: Never commit .env to version control — it is in .gitignore.
#            Restrict file permissions: chmod 600 .env
# =============================================

# ── PostgreSQL / Drupal ───────────────────────────────────────────────────────
# Primary database password — used by both Drupal and the postgres service.
# Generate: openssl rand -base64 32
DRUPAL_DB_PASSWORD=

# ── PostgreSQL / Keycloak ─────────────────────────────────────────────────────
# Keycloak uses its own dedicated database — do NOT reuse DRUPAL_DB_PASSWORD.
# Generate: openssl rand -base64 32
KEYCLOAK_DB_PASSWORD=

# ── Keycloak Admin ────────────────────────────────────────────────────────────
# Keycloak web admin console password (username is always 'admin').
# Generate: openssl rand -base64 32
KEYCLOAK_ADMIN_PASSWORD=

# ── Redis ─────────────────────────────────────────────────────────────────────
# Password for Redis AUTH command — prevents unauthenticated connections if the
# Redis port is ever accidentally exposed. Must match REDIS_PASSWORD in Drupal settings.
# Generate: openssl rand -base64 32
REDIS_PASSWORD=

# ── Drupal ────────────────────────────────────────────────────────────────────
# Cryptographic hash salt — must be long, random, and NEVER changed after launch.
# Changing this invalidates all sessions, one-time login links, and CSRF tokens.
# Generate: openssl rand -base64 55
DRUPAL_HASH_SALT=

# OAuth2 consumer credentials — created in Drupal at /admin/config/services/consumer.
DRUPAL_CLIENT_ID=
DRUPAL_CLIENT_SECRET=

# Secret for on-demand Next.js ISR revalidation.
# Generate: openssl rand -base64 32
# Set the same value in Drupal at /admin/config/services/next.
DRUPAL_REVALIDATE_SECRET=

# Secret for draft/preview mode — must match the Drupal Next.js module config.
DRUPAL_PREVIEW_SECRET=

# ── Next.js ───────────────────────────────────────────────────────────────────
# Domain used for Next.js image optimization proxy.
# Dev (Dockerized): use 'drupal' (Docker service name)
# Prod (VPS):       use 'api.wilkesliberty.com'
NEXT_IMAGE_DOMAIN=api.wilkesliberty.com

# ── Grafana ───────────────────────────────────────────────────────────────────
# Bootstrap admin password — used on first start only.
# Rotate via Grafana UI after first login; do not leave as default.
# Generate: openssl rand -base64 32
GRAFANA_ADMIN_PASSWORD=

# Grafana → Keycloak OAuth2 (recommended — disables local password login once enabled).
# Set up the Grafana client in Keycloak first, then fill in these values.
# GF_AUTH_GENERIC_OAUTH_ENABLED=true
# GF_AUTH_GENERIC_OAUTH_NAME=Keycloak
# GF_AUTH_GENERIC_OAUTH_CLIENT_ID=grafana
# GF_AUTH_GENERIC_OAUTH_CLIENT_SECRET=<keycloak-client-secret>
# GF_AUTH_GENERIC_OAUTH_SCOPES=openid profile email
# GF_AUTH_GENERIC_OAUTH_AUTH_URL=https://auth.wilkesliberty.com/realms/wilkesliberty/protocol/openid-connect/auth
# GF_AUTH_GENERIC_OAUTH_TOKEN_URL=https://auth.wilkesliberty.com/realms/wilkesliberty/protocol/openid-connect/token
# GF_AUTH_GENERIC_OAUTH_API_URL=https://auth.wilkesliberty.com/realms/wilkesliberty/protocol/openid-connect/userinfo
# GF_AUTH_DISABLE_LOGIN_FORM=true
# GF_AUTH_SIGNOUT_REDIRECT_URL=https://auth.wilkesliberty.com/realms/wilkesliberty/protocol/openid-connect/logout

# ── Backup ────────────────────────────────────────────────────────────────────
# Email address for backup status notifications.
BACKUP_NOTIFICATION_EMAIL=3@wilkesliberty.com

# AES-256 encryption key for backup archives — REQUIRED in production.
# Do not leave empty: unencrypted backups on NAS or cloud storage are a data breach risk.
# Generate: openssl rand -base64 32
# Store a copy of this key separately (password manager, printed in a safe location)
# — without it, backups cannot be decrypted.
BACKUP_ENCRYPTION_KEY=

# ── Alertmanager SMTP ─────────────────────────────────────────────────────────
# Alertmanager config is rendered by Ansible from config.yml.j2 — not by Docker.
# SMTP credentials go in ansible/inventory/group_vars/sso_secrets.yml (SOPS-encrypted).
# SMTP host/port/from/to are in ansible/inventory/group_vars/all.yml.
# Ref only — NOT read by docker-compose:
#
#   alert_smtp_user: <proton-smtp-user>       → sso_secrets.yml (SOPS-encrypted)
#   alert_smtp_password: <proton-smtp-pass>   → sso_secrets.yml (SOPS-encrypted)
#   alert_slack_webhook_url: <webhook>        → sso_secrets.yml (SOPS-encrypted, optional)
