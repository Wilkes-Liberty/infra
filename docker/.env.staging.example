# WilkesLiberty Staging — environment variable template
#
# Copy to .env in ~/nas_docker_staging/ and fill in values:
#   cp .env.staging.example ~/nas_docker_staging/.env
#
# All staging variables are prefixed STG_ to avoid collisions if this file
# is ever merged with production .env for tooling purposes.
#
# Generate secure values:
#   openssl rand -base64 32    (passwords and secrets)
#   openssl rand -base64 55    (Drupal hash salt)

# ── PostgreSQL / Drupal (staging) ─────────────────────────────────────────────
STG_DRUPAL_DB_PASSWORD=

# ── PostgreSQL / Keycloak (staging) ──────────────────────────────────────────
STG_KEYCLOAK_DB_PASSWORD=

# ── Keycloak Admin (staging) ─────────────────────────────────────────────────
STG_KEYCLOAK_ADMIN_PASSWORD=

# ── Redis (staging) ──────────────────────────────────────────────────────────
STG_REDIS_PASSWORD=

# ── Drupal (staging) ─────────────────────────────────────────────────────────
STG_DRUPAL_HASH_SALT=

# OAuth2 consumer credentials — created in staging Drupal
STG_DRUPAL_CLIENT_ID=drupal-client
STG_DRUPAL_CLIENT_SECRET=

# ISR revalidation secret — set the same value in staging Drupal
STG_DRUPAL_REVALIDATE_SECRET=

# ── Next.js (staging) ────────────────────────────────────────────────────────
# 'drupal' = use Docker service name for SSR requests (correct for staging)
NEXT_STG_IMAGE_DOMAIN=drupal
