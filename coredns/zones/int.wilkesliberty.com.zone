$ORIGIN int.wilkesliberty.com.
@   3600 IN SOA ns.int.wilkesliberty.com. hostmaster.wilkesliberty.com. (
        2026033001 ; serial (YYYYMMDDNN — increment NN on same-day edits)
        3600       ; refresh
        900        ; retry
        604800     ; expire
        86400 )    ; minimum
    IN NS ns.int.wilkesliberty.com.

; ── DNS server ────────────────────────────────────────────────────────────────
ns         IN A 10.10.0.10

; ── Application services (on-prem server) ────────────────────────────────────
app        IN A 10.10.0.2
sso        IN A 10.10.0.8

; ── Data services (no Caddy proxy — DNS only for internal tooling) ────────────
db         IN A 10.10.0.3
search     IN A 10.10.0.4
cache      IN A 10.10.0.9

; ── Monitoring & observability ────────────────────────────────────────────────
monitor    IN A 10.10.0.7
prometheus IN A 10.10.0.7
alerts     IN A 10.10.0.7
uptime     IN A 10.10.0.7

; ── Admin devices ─────────────────────────────────────────────────────────────
; TODO: Replace placeholder IPs with actual LAN IPs for each device.
; Tip: assign static/reserved DHCP leases so these never drift.
; Run `arp -a` or check your router's DHCP table to find current IPs.
nas        IN A 10.10.0.20   ; NAS storage (e.g. Synology, TrueNAS)
router     IN A 10.10.0.1    ; Router/gateway admin UI
switch     IN A 10.10.0.2    ; TP-Link managed switch admin UI — TODO: set actual IP
printer    IN A 10.10.0.30   ; Network printer admin UI — TODO: set actual IP
