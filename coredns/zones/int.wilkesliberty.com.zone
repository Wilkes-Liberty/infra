$ORIGIN int.wilkesliberty.com.
@   3600 IN SOA ns.int.wilkesliberty.com. hostmaster.wilkesliberty.com. (
        2026033101 ; serial (YYYYMMDDNN — increment NN on same-day edits)
        3600       ; refresh
        900        ; retry
        604800     ; expire
        86400 )    ; minimum
    IN NS ns.int.wilkesliberty.com.

; ── DNS server ────────────────────────────────────────────────────────────────
ns         IN A 10.10.0.10

; ── Application services (on-prem server) ────────────────────────────────────
; These resolve to the on-prem server's LAN IP so internal traffic stays on-net.
; Internal Caddy (Caddyfile.internal.j2) handles TLS and routing for these hosts.
app        IN A 10.10.0.2   ; Drupal CMS (webcms repo) — also public: api.wilkesliberty.com
sso        IN A 10.10.0.8   ; Keycloak SSO — also public: auth.wilkesliberty.com

; ── Data & search services (DNS only — accessed directly, no Caddy proxy) ─────
db         IN A 10.10.0.3
search     IN A 10.10.0.4   ; Solr search (webcms repo uses this internally)
cache      IN A 10.10.0.9   ; Redis/Varnish cache

; ── Monitoring & observability ────────────────────────────────────────────────
monitor    IN A 10.10.0.7   ; Grafana dashboards
metrics    IN A 10.10.0.7   ; Prometheus metrics (admin-CIDR restricted)
alerts     IN A 10.10.0.7   ; Alertmanager (admin-CIDR restricted)
uptime     IN A 10.10.0.7   ; Uptime Kuma

; ── Network admin ─────────────────────────────────────────────────────────────
; Generic alias for the Tailscale/VPN admin console (resolves on tailnet devices)
network    IN CNAME login.tailscale.com.

; ── Admin devices ─────────────────────────────────────────────────────────────
; TODO: Replace placeholder IPs with actual static/reserved DHCP IPs for each device.
; Assign static leases on your router so these never drift.
; Run `arp -a` or check your router's DHCP table to find current IPs.
; Caddy proxies each of these at *.int.wilkesliberty.com with the wildcard TLS cert.
nas        IN A 10.10.0.20   ; Synology NAS (nas.int.wilkesliberty.com) — TODO: set actual IP
router     IN A 10.10.0.1    ; AT&T router admin UI (router.int.wilkesliberty.com)
switch     IN A 10.10.0.50   ; TP-Link managed switch (switch.int.wilkesliberty.com) — TODO: set actual IP
printer    IN A 10.10.0.30   ; Network printer admin UI (printer.int.wilkesliberty.com) — TODO: set actual IP
print      IN CNAME printer.int.wilkesliberty.com. ; Alias: print.int.wilkesliberty.com → printer
